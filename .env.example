# SMC Trading Bot ? Environment Variables
# Copy this file to .env and fill in your values

# === ANTHROPIC (Claude API) ===
ANTHROPIC_API_KEY=

# === BINANCE ===
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# === METATRADER 5 (Windows only, skipped on Railway/Linux) ===
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=Axi-US50-Demo
MT5_DEMO=true

# === GLINT (optional) ===
GLINT_EMAIL=
GLINT_SESSION_TOKEN=
GLINT_WS_URL=wss://glint.trade/ws

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === BOT PARAMETERS ===
MAX_RISK_PER_TRADE=0.005
MAX_DAILY_LOSS=0.05
MAX_MONTHLY_LOSS=0.15
MAX_OPEN_POSITIONS=3
OPERATION_MODE=auto
DEFAULT_TIMEFRAMES=5m,15m,1h,4h
